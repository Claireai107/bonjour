# Anthropic API 키 — 검진표 OCR을 Claude 비전으로 처리 (정확도 대폭 향상).
# https://platform.claude.com 에서 발급. 없으면 기기 내 tesseract OCR로 폴백.
ANTHROPIC_API_KEY=

# Gemini 비전 OCR — aistudio.google.com 에서 무료 발급 (Claude 키 없을 때 사용)
GEMINI_API_KEY=

# 카카오 REST API 키 — developers.kakao.com 앱의 'REST API 키'
# 현재위치→주소 변환, 내 주변 보건소 검색에 사용. 없으면 데모 데이터로 동작.
KAKAO_REST_API_KEY=
